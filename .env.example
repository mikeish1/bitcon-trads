# =============================================================================
# Environment variables - Spot Long-Only BTC Bot (Binance.US or Alpaca)
# =============================================================================
# LOCAL: copy this to ".env" (cp .env.example .env) and fill in your values.
# RAILWAY: add each of these in the project's "Variables" tab instead.
# NEVER commit your real .env or paste real keys anywhere public.
# =============================================================================

# --- Which venue -------------------------------------------------------------
# "binanceus" = Binance.US spot (real money only; internal simulation in paper).
# "alpaca"    = Alpaca, which has a real PAPER account -> best for safe testing.
EXCHANGE_ID=alpaca

# --- THE TWO-KEY LIVE TRIPWIRE (real money) ---------------------------------
# Real-money orders need BOTH of these. Default = safe.
#   Binance.US live: PAPER_TRADING=false AND LIVE_TRADING_ENABLED=true
#   Alpaca live:     ALPACA_PAPER=false  AND the two switches above
PAPER_TRADING=true
LIVE_TRADING_ENABLED=false

# --- Alpaca ------------------------------------------------------------------
# Keys from https://alpaca.markets/ (use your PAPER account keys).
# ALPACA_PAPER=true routes orders to the paper endpoint (no real money).
ALPACA_PAPER=true
ALPACA_API_KEY=
ALPACA_API_SECRET=

# --- Binance.US (only if EXCHANGE_ID=binanceus) ------------------------------
# Account -> API Management. Enable Spot Trading, DO NOT enable withdrawals.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Optional: override the traded symbol. Defaults: BTC/USD on Alpaca,
# BTC/USDT on Binance.US.
# SYMBOL=BTC/USD

# --- Claude API (optional) ---------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- Telegram alerts (optional) ----------------------------------------------
# Get phone alerts for entries, exits, daily summaries, and circuit breakers.
# Leave the token/chat id blank to disable (the bot runs fine without them).
# See the README "Telegram notifications" section for how to get these.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Money knobs (optional) --------------------------------------------------
DEFAULT_CAPITAL_USD=250      # used only in internal-simulation mode
# RISK_PER_TRADE_PCT=0.01
# DAILY_LOSS_LIMIT_PCT=0.03
# WEEKLY_LOSS_LIMIT_PCT=0.07
# LOG_LEVEL=INFO

DB_PATH=trading_state.db
