# =============================================================================
# Environment variables for the Bitcoin Ensemble Trading System
# =============================================================================
# Copy this file to ".env" for LOCAL runs:   cp .env.example .env
# On Railway, add each of these in the project's "Variables" tab instead.
#
# NEVER commit your real .env file or paste real keys into code.
# =============================================================================

# --- SAFETY SWITCH -----------------------------------------------------------
# "true"  = PAPER TRADING (simulated fills, no real orders). <-- START HERE.
# "false" = LIVE TRADING (places real orders). Only flip once you fully trust it.
PAPER_TRADING=true

# --- Binance API keys --------------------------------------------------------
# For PAPER trading, create keys on the Binance Futures TESTNET:
#   https://testnet.binancefuture.com/
# For LIVE trading, use your real Binance keys (and accept the risk).
# In paper mode you can even leave these blank - public data still works.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Use Binance Futures TESTNET for paper trading (recommended).
BINANCE_TESTNET=true

# --- Claude API --------------------------------------------------------------
# Get a key at https://console.anthropic.com/
# Used sparingly: only for borderline trade decisions + a daily summary.
ANTHROPIC_API_KEY=

# Optional: override the model. Default is the cheap "claude-haiku-4-5".
# (You could set "claude-opus-4-8" for maximum quality at higher cost.)
CLAUDE_MODEL=claude-haiku-4-5

# --- Optional overrides (otherwise config/trading_config.yaml is used) --------
# STARTING_CAPITAL_USD=1000
# MAX_RISK_PER_TRADE=0.01
# KELLY_FRACTION=0.25
# DAILY_LOSS_LIMIT_PCT=0.03
# WEEKLY_LOSS_LIMIT_PCT=0.07
# LOG_LEVEL=INFO

# Path to the SQLite database file (state + trade log). Default shown.
DB_PATH=trading_state.db
