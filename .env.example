# =============================================================================
# Environment variables - Binance.US Spot Long-Only Bot
# =============================================================================
# LOCAL: copy this to ".env" (cp .env.example .env) and fill in your values.
# RAILWAY: add each of these in the project's "Variables" tab instead.
# NEVER commit your real .env or paste real keys into code.
# =============================================================================

# --- THE TWO-KEY LIVE TRIPWIRE ----------------------------------------------
# Real orders are placed ONLY when BOTH of these are set for live:
#   PAPER_TRADING=false   AND   LIVE_TRADING_ENABLED=true
# Any other combination = safe PAPER mode (simulated, no real money).
PAPER_TRADING=true
LIVE_TRADING_ENABLED=false

# --- Exchange ----------------------------------------------------------------
# This system is built for Binance.US spot. Leave as binanceus.
EXCHANGE_ID=binanceus

# --- Binance.US API keys -----------------------------------------------------
# Create at https://www.binance.us/ -> Account -> API Management.
# Permissions: ENABLE "Spot Trading". DO NOT enable withdrawals.
# Recommended: restrict the key to your home IP address.
# In PAPER mode the bot runs on public data; keys are only required for live
# trading and for reading your real balance.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Claude API (optional) ---------------------------------------------------
# Used sparingly: a yes/no on borderline setups + a daily summary.
# Leave blank to run without it (borderline setups proceed on the rules alone).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- Money knobs (optional; otherwise config/trading_config.yaml is used) -----
DEFAULT_CAPITAL_USD=250      # assumed capital in paper mode / fallback
# RISK_PER_TRADE_PCT=0.01    # risk per trade (1%)
# DAILY_LOSS_LIMIT_PCT=0.03
# WEEKLY_LOSS_LIMIT_PCT=0.07
# LOG_LEVEL=INFO

# Where the trade log / state database lives.
DB_PATH=trading_state.db
