# Frontend dev configuration (copy to .env for local overrides).

# Where `vite dev` proxies /api during local development. Point this at the running
# FastAPI dashboard. Defaults to http://localhost:8080 if unset.
VITE_DEV_API_TARGET=http://localhost:8080

# Optional: bake an API token into a dev build. Prefer leaving this UNSET and the
# backend open (no DASHBOARD_TOKEN) for local dev, so the token is never bundled.
# VITE_DASHBOARD_TOKEN=
